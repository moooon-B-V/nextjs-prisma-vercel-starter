// Prisma schema. Add your models here.
//
// Prisma 7 note: the datasource URL lives in `prisma.config.ts` (loaded at
// CLI startup), not here. This file declares only the provider and models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Placeholder model that exists only so the initial migration has something
/// to apply (Prisma needs at least one model to create a non-empty migration).
/// Delete this once you add your real models, or rename it to whatever your
/// first real entity is.
model Marker {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
}
