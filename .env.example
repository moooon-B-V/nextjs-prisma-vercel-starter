# Local dev DB (run `./scripts/db-up.sh` to start Postgres in Docker).
# Host port is 5433 (not 5432) to avoid colliding with other local Postgres
# instances. The container internally uses 5432.
DATABASE_URL="postgresql://nextjs_prisma_vercel_starter:nextjs_prisma_vercel_starter@localhost:5433/nextjs_prisma_vercel_starter"

# In production on Vercel, the Neon integration sets DATABASE_URL (pooled)
# AND DATABASE_URL_UNPOOLED (direct connection for migrations). Prisma config
# reads UNPOOLED for migrations, falls back to DATABASE_URL for local dev
# where there's no pooler distinction.
# DATABASE_URL_UNPOOLED=
