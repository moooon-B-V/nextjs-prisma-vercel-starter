# Local dev DB (run `./scripts/db-up.sh` to start Postgres in Docker).
# Host port is 5433 (not 5432) to avoid colliding with other local Postgres
# instances. The container internally uses 5432.
DATABASE_URL="postgresql://nextjs_prisma_vercel_starter:nextjs_prisma_vercel_starter@localhost:5433/nextjs_prisma_vercel_starter"

# In production on Vercel, the Neon integration sets DATABASE_URL (pooled)
# AND DATABASE_URL_UNPOOLED (direct connection for migrations). Prisma config
# reads UNPOOLED for migrations, falls back to DATABASE_URL for local dev
# where there's no pooler distinction.
# DATABASE_URL_UNPOOLED=

# ---------------------------------------------------------------------------
# Auth — Better-Auth (see lib/auth/index.ts)
# ---------------------------------------------------------------------------

# BETTER_AUTH_SECRET: required. Used to sign session cookies. Generate a
# fresh 32-byte secret for each environment with:
#   openssl rand -base64 32
# In production, store this in the Vercel dashboard (Settings → Environment
# Variables). Rotating the secret invalidates all active sessions.
BETTER_AUTH_SECRET=

# BETTER_AUTH_URL: the public origin Better-Auth uses to build callback
# URLs (OAuth round-trips, email links). Optional in local dev — defaults
# to http://localhost:3000 — but MUST be set in production to the canonical
# public URL (e.g. https://your-app.vercel.app). Setting Vercel's automatic
# VERCEL_URL is not enough because it omits the protocol.
# BETTER_AUTH_URL=http://localhost:3000

# NEXT_PUBLIC_BETTER_AUTH_URL: the public origin the client-side
# Better-Auth React SDK uses for API calls. Optional — defaults to the
# current origin at request time, which works for any single-origin
# deployment. Set this only if your client runs on a different origin than
# your auth API (multi-origin / sub-domain setups).
# NEXT_PUBLIC_BETTER_AUTH_URL=

# Email provider — see lib/email.ts.
# 'console' (default) prints emails to stdout so dev/test flows can grep
# the reset link. Production providers ('resend', 'postmark', …) are NOT
# YET WIRED in this starter: choose one and wire it in lib/email.ts.
# Setting one of the un-wired values will throw at module load with a
# clear message.
EMAIL_PROVIDER=console

# Google OAuth — required. The Google "Continue with Google" button needs
# both. Obtain them at:
#   Google Cloud Console → APIs & Services → Credentials
#     → Create Credentials → OAuth 2.0 Client ID → Web application
# Authorized redirect URI to enter at Google:
#   {BETTER_AUTH_URL}/api/auth/callback/google
#   (local dev: http://localhost:3000/api/auth/callback/google)
# Missing values throw at module-load time so misconfiguration surfaces
# loudly, not at click time. If you don't want Google sign-in, delete the
# socialProviders block from lib/auth/index.ts AND remove the GoogleButton
# from the auth pages.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
